                            "type": "integer",
                            "format": "int32",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Affichage d'un livre avec son id.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "id": {
                                            "type": "integer",
                                            "format": "int32",
                                            "example": 1
                                        },
                                        "bibliotheque_id": {
                                            "type": "integer",
                                            "format": "int32",
                                            "example": 3
                                        },
                                        "titre": {
                                            "type": "string",
                                            "example": "Powerless"
                                        },
                                        "auteur": {
                                            "type": "string",
                                            "example": "Lauren Roberts"
                                        },
                                        "description": {
                                            "type": "string",
                                            "example": "616 pages : 1 illustration ; 23 cm"
                                        },
                                        "isbn": {
                                            "type": "string",
                                            "example": "9782898113321"
                                        },
                                        "date_ajout": {
                                            "type": "string",
                                            "example": "2023-07-1T04:00:00.000Z"
                                        },
                                        "disponible": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        
                                        "type": "array",
                                        "prets": {
                                            "items": {
                                        "type": "object",
                                        "properties": {
                                            "id": {
                                                "type": "integer",
                                                "format": "int32",
                                                "example": 1
                                            },
                                            "livre_id": {
                                                "type": "integer",
                                                "format": "int32",
                                                "example": 3
                                            },
                                            "emprunteur": {
                                                "type": "string",
                                                "example": "Christine Lehoux"
                                            },
                                            "date_retour": {
                                                "type": "string",
                                                "example": "2023-07-1T04:00:00.000Z"
                                            },
                                            "disponible": {
                                                "type": "boolean",
                                                "example": true
                                            }
                                        }
                                    }

                                    }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Clé API manquante ou invalide",
                        "content": {
                            "application/json": {
                                "example": {
                                    "message": "Clé API invalide"
                                }
                            }
                        }
                    },
                    "500":{
                        "description": "Récupération du livre non rencontrée",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Échec lors de la récupération du livre"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
