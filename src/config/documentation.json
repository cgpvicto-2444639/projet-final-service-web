    "info":{
       "title": "Bibliothèque API",
        "summary": "Mon API créer des bibliothèques, contenant des livres qui peuvent être prêtés, puis ceux-ci se font gérer par mon API, la bibliothèque.",
        "description": "Mon API peux créer des bibliothèques, des livres et des prêts. Avec les routes, nous pouvons contrôler la généralité de ce qu'une bibliothèque fait normalement, donc enregistrer des livres et les prêter aux lecteurs.",
        "contact": {
            "name": "API Support",
            "url": "https://www.example.com/support",
            "email": "support@example.com"
        },
        "version": "1.0.1"
    },
        "servers": [
        {
            "url": "http://127.0.0.1:3000/",
            "description": "Serveur de développement"
        },
        {
            "url": "mon serveur sur Render",
            "description": "Serveur en ligne"
        }
    ],
    "paths": {
        "/api/bibliotheque/liste": {
            "get": {
                "summary": "Affichage de la liste de livre selon la disponibilité dans la bibliothèque",
                "tags": ["LivresAffiche"],
                "parameters": [
                    {
                        "in": "query",
                        "name": "tous",
                        "description": "Pour afficher tout les livres.",
                        "schema": {
                            "type": "boolean",
                            "example": true
                        },
                        "required": false
                    }
                ],
                "security": [
                    { "ApiKeyAuth": [] }
                ],
                "responses": {
                    "200": {
                        "description": "Retourne une liste de livres",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "id": {
                                                "type": "integer",
                                                "format": "int32",
                                                "example": 1
                                            },
                                            "bibliotheque_id": {
                                                "type": "integer",
                                                "format": "int32",
                                                "example": 3
                                            },
                                            "titre": {
                                                "type": "string",
                                                "example": "Powerless"
                                            },
                                            "auteur": {
                                                "type": "string",
                                                "example": "Lauren Roberts"
                                            },
                                            "description": {
                                                "type": "string",
                                                "example": "616 pages : 1 illustration ; 23 cm"
                                            },
                                            "isbn": {
                                                "type": "string",
                                                "example": "9782898113321"
                                            },
                                            "date_ajout": {
                                                "type": "string",
                                                "example": "2023-07-1T04:00:00.000Z"
                                            },
                                            "disponible": {
                                                "type": "boolean",
                                                "example": false
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Clé API manquante ou invalide",
                        "content": {
                            "application/json": {
                                "example": {
                                    "message": "Clé API invalide"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Récupération de la liste de livres non rencontrée",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Echec lors de la récupération de la liste des livres"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/bibliotheque/livre/{id}": {
            "get": {
                "summary": "Affichage d'un livre en particulier venant de l'id que l'utilisateur mettra dans l'url de la route.",
